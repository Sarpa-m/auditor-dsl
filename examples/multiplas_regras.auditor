REGRA "Aliquota PIS incorreta"
ANALISAR NFE
FILTRAR ITEM ONDE ITEM_CST_ICMS == "000"
VALIDAR ITEM QUE ITEM_ALIQUOTA_PIS == 1.65%
AO_FALHAR ALERTA "PIS nao cumulativo fora do padrao."

REGRA "Operacao Interestadual sem ICMS"
ANALISAR NFE
FILTRAR NOTA ONDE NOTA_UF_EMITENTE == "SP"
E NOTA_UF_DESTINATARIO != "SP"
VALIDAR NOTA QUE NOTA_VALOR_ICMS > 0
AO_FALHAR REJEITAR "Operacao interestadual sem ICMS destacado."
